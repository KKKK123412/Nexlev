# ─── YouTube Data API v3 ───────────────────────────────────────────────────
# Get your free API key at: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in your Google Cloud project
# Free tier: 10,000 units/day
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─── Optional: Upstash Redis (persistent caching across deployments) ────────
# Free tier at: https://upstash.com
# If not set, NEXLEV uses in-memory cache (resets on cold start)
# UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ─── App settings ───────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
